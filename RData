## Layer 3: Survival Analysis

### 3.1 Canine OSA Survival (DOG2 Clinical Data)

```{r canine-survival, eval=FALSE}
# Load clinical metadata
clin <- read_excel("COTC022 SOC Data Set.xlsx")

# Calculate survival days from surgery dates
clin$OS_days   <- as.numeric(difftime(clin$`Date off study`,
                                       clin$`Date of Surgery`,
                                       units = "days"))
clin$OS_status <- as.numeric(clin$`Cause of death (OSA, Unknown, Other)` == "OSA")

# Match patient IDs between RNA-seq and clinical data
rna_ids <- sapply(colnames(dog2), function(x) strsplit(x, "_")[[1]][2])
common_ids <- intersect(rna_ids, clin$`Patient ID`)
cat("Matched samples:", length(common_ids), "\n")
# Result: 97 samples matched

# Extract SRGN expression for matched samples
srgn_matched <- log2(as.numeric(
  dog2["SRGN_3", names(rna_ids[rna_ids %in% common_ids])]) + 1)
names(srgn_matched) <- rna_ids[rna_ids %in% common_ids]

clin_matched <- clin[match(names(srgn_matched), clin$`Patient ID`), ]

# Build survival dataframe
surv_df <- data.frame(
  OS_days    = clin_matched$OS_days,
  OS_status  = clin_matched$OS_status,
  SRGN_expr  = srgn_matched,
  SRGN_group = ifelse(srgn_matched >= median(srgn_matched),
                      "SRGN High", "SRGN Low")
)

# Kaplan-Meier plot
fit <- survfit(Surv(OS_days, OS_status) ~ SRGN_group, data = surv_df)
ggsurvplot(fit,
           data         = surv_df,
           pval         = TRUE,
           risk.table   = TRUE,
           palette      = c("#E41A1C", "#377EB8"),
           title        = "SRGN expression and OS in canine OSA (n=97)")
# Result: p = 0.94 — no significant association
# Interpretation: SRGN is mechanistic, not prognostic in bulk OSA
```

### 3.2 Human OSA Recurrence Analysis (GSE39055)

```{r human-survival, eval=FALSE}
# Load GSE39055 series matrix
gse39    <- getGEO(filename = "GSE39055_series_matrix.txt.gz")
expr39   <- exprs(gse39)
pheno39  <- pData(gse39)

# Get SRGN probe IDs from GPL14951
gpl39       <- getGEO(annotation(gse39))
gpl39_table <- Table(gpl39)
srgn_probes <- gpl39_table[gpl39_table$Symbol == "SRGN", "ID"]
# Result: ILMN_1760347, ILMN_2169152

# Average expression across both probes
srgn_expr39 <- colMeans(expr39[rownames(expr39) %in% srgn_probes, ])

# Build survival dataframe
surv_human <- data.frame(
  time_months = as.numeric(pheno39$`time until first recurrence or latest follow-up (months):ch1`),
  recurrence  = as.numeric(pheno39$`recurrence:ch1` == "Y"),
  SRGN        = srgn_expr39,
  SRGN_group  = ifelse(srgn_expr39 >= median(srgn_expr39), "SRGN High", "SRGN Low")
)

# Kaplan-Meier
fit_human <- survfit(Surv(time_months, recurrence) ~ SRGN_group, data = surv_human)
ggsurvplot(fit_human,
           data       = surv_human,
           pval       = TRUE,
           risk.table = TRUE,
           palette    = c("#E41A1C", "#377EB8"),
           title      = "SRGN expression and recurrence in human OSA - GSE39055 (n=37)")
# Result: p = 0.72 — consistent with canine finding
```

